{
  "manifest_version": 2,
  "name": "EigenVault Password Manager",
  "version": "1.0.0",
  "description": "Secure password generator and manager with biometric unlock and smart auto-fill",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "EigenVault"
  },
  "background": {
    "scripts": ["background/service-worker.js"],
    "persistent": false
  },
  "permissions": [
    "storage",
    "tabs",
    "contextMenus",
    "clipboardWrite",
    "unlimitedStorage",
    "webNavigation",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    "styles/*"
  ],
  "commands": {
    "_execute_browser_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      }
    },
    "autofill": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Auto-fill credentials on current page"
    },
    "generate": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Generate new password"
    }
  },
  "content_security_policy": "script-src 'self'; object-src 'self'",
  "browser_specific_settings": {
    "gecko": {
      "id": "eigenvault@nihal.dev",
      "strict_min_version": "109.0"
    }
  }
}
